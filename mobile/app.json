{
  "expo": {
    "name": "Atelier",
    "slug": "atelier",
    "owner": "crisp1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "atelier",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.aunflaneur.atelier"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f5f3ec",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.aunflaneur.atelier",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f5f3ec",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Atelier accesses your photos so you can post your work."
        }
      ],
      "expo-video",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fcdeccec-a57f-477e-a928-6a5879a1a9c7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
