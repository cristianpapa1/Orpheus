# Atelier — environment configuration
# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings → API). Without these, the app runs in preview mode:
# the shell renders but sign-in is disabled.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Absolute URL of this deployment — used for auth redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Donations (Phase 7) ──────────────────────────────────────────
# Stripe secret key (sk_test_… / sk_live_…) — enables the /donate flow.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_…) for /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=
# Supabase service-role key — used ONLY by the Stripe webhook to record
# donations (server-side only; never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=

# ── Analytics (PostHog) ──────────────────────────────────────────
# Session replay + product analytics. Unset → analytics is a no-op.
# Project API key (phc_…) from your PostHog project.
NEXT_PUBLIC_POSTHOG_KEY=
# Ingestion host — match your project's region (US: https://us.i.posthog.com,
# EU: https://eu.i.posthog.com). Client + server both read this.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
